<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fishing Game"
        android:textSize="24sp"
        android:textAlignment="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/textViewRod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rod: Default Rod"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/textViewLure"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lure: Default Lure"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/textViewSkillLevel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Skill Level: 1"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/buttonUpgradeLure"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upgrade Lure"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/buttonUpgradeRod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upgrade Rod"/>
    </LinearLayout>
</LinearLayout>